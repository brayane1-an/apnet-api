rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Dossier avatars/ : Tout le monde peut voir, seul le propriétaire peut modifier sa photo.
    match /avatars/{userId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Dossier kyc_documents/ : Strictement privé (CNI, CV, Titres). Seul l'admin et le propriétaire y accèdent.
    match /kyc_documents/{userId}/{allPaths=**} {
      allow read, write: if request.auth != null && (
        request.auth.uid == userId || 
        firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'ADMIN'
      );
    }

    // Dossier identites/ : Ancien dossier (Legacy)
    match /identities/{userId}/{allPaths=**} {
      allow read, write: if request.auth != null && (
        request.auth.uid == userId || 
        firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'ADMIN'
      );
    }
  }
}
